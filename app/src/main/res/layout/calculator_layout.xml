<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/calculator_display"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="end|center_vertical"
        android:textSize="32sp"
        android:text="0"
        android:padding="16dp"
        android:background="#F5F5F5"
        android:layout_marginBottom="16dp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="4"
        android:rowCount="5">

        <Button android:id="@+id/btn_7" android:text="7" android:textSize="20sp" />
        <Button android:id="@+id/btn_8" android:text="8" android:textSize="20sp" />
        <Button android:id="@+id/btn_9" android:text="9" android:textSize="20sp" />
        <Button android:id="@+id/btn_divide" android:text="÷" android:textSize="20sp" />

        <Button android:id="@+id/btn_4" android:text="4" android:textSize="20sp" />
        <Button android:id="@+id/btn_5" android:text="5" android:textSize="20sp" />
        <Button android:id="@+id/btn_6" android:text="6" android:textSize="20sp" />
        <Button android:id="@+id/btn_multiply" android:text="×" android:textSize="20sp" />

        <Button android:id="@+id/btn_1" android:text="1" android:textSize="20sp" />
        <Button android:id="@+id/btn_2" android:text="2" android:textSize="20sp" />
        <Button android:id="@+id/btn_3" android:text="3" android:textSize="20sp" />
        <Button android:id="@+id/btn_subtract" android:text="−" android:textSize="20sp" />

        <Button android:id="@+id/btn_0" android:text="0" android:textSize="20sp" />
        <Button android:id="@+id/btn_decimal" android:text="." android:textSize="20sp" />
        <Button android:id="@+id/btn_equal" android:text="=" android:textSize="20sp" />
        <Button android:id="@+id/btn_add" android:text="+" android:textSize="20sp" />

        <Button android:id="@+id/btn_clear"
            android:text="C"
            android:textSize="20sp"
            android:layout_columnSpan="4"
            android:layout_gravity="fill" />
    </GridLayout>

    <Button
        android:id="@+id/vault_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔒 Open Vault"
        android:textSize="18sp"
        android:layout_marginTop="16dp"
        android:background="#2196F3"
        android:textColor="#FFFFFF" />

</LinearLayout>